# Server Configuration
PORT=3131
NODE_ENV=development

# Database
MONGODB_URI=mongodb://mongodb:27017/silver-glow
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/silver-glow

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL
# Development
FRONTEND_URL=http://localhost:3030
# Production
# FRONTEND_URL=https://silverglow.store

# Cookie Configuration
COOKIE_DOMAIN=
# For production with subdomain:
# COOKIE_DOMAIN=.silverglow.store
USE_HTTPS=false
COOKIE_HTTP_ONLY=true

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@admin.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_PHONE=201018939831
DEFAULT_ADMIN_ADDRESS=123 Main St, Anytown, USA
DEFAULT_ADMIN_NAME=Super Admin

# Google API
GOOGLE_API_KEY=your-google-api-key

# WhatsApp API (Wasel)
WASEL_API_TOKEN=your-wasel-api-token
WASEL_INSTANCE_ID=your-instance-id
